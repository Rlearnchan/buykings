# Copy to .env at repo root on the Windows server and fill in the values.

DATAWRAPPER_ACCESS_TOKEN=replace_me
NOTION_API_KEY=replace_me

# Choose one backend strategy.
WEPOLL_SECOND_PASS_BACKEND=ollama
OLLAMA_HOST=http://127.0.0.1:11434
OPENAI_API_KEY=

# Optional override when wepoll-panic is not a sibling directory.
WEPOLL_PANIC_ROOT=

# Autopark Windows daily Notion server.
AUTOPARK_CDP_ENDPOINT=http://127.0.0.1:9222
AUTOPARK_PUBLISH_POLICY=gate
AUTOPARK_STATE_ROOT=C:\ops\buykings\.server-state\autopark

# Optional when Chrome is not in the default Program Files location.
AUTOPARK_CHROME_PATH=

# Optional notes:
# - Default fetcher URL is http://127.0.0.1:8777
# - Default morning job reads config/buykings-morning.json
# - Autopark keeps browser profiles and mirrored run artifacts out of Git.
