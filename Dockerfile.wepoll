FROM mcr.microsoft.com/playwright:v1.59.1-noble

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONUTF8=1
ENV PIP_NO_CACHE_DIR=1
ENV TZ=Asia/Seoul
ENV LANG=C.UTF-8
ENV LC_ALL=C.UTF-8
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 python3-pip python3-venv tzdata ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json requirements-server.txt /app/
RUN npm ci \
    && python3 -m pip install --break-system-packages -r requirements-server.txt

COPY . /app

ENV WEPOLL_FETCHER_URL=http://wepoll-fetcher:8777
ENV WEPOLL_FETCHER_USER_DATA_DIR=/state/fetcher-profile
ENV WEPOLL_DOWNLOAD_DIR=/app/runtime/downloads/wepoll
ENV WEPOLL_MANIFEST_DIR=/app/runtime/logs/wepoll-fetcher
ENV WEPOLL_PANIC_ROOT=/app/vendor/wepoll-panic
ENV WEPOLL_SECOND_PASS_BACKEND=openai
ENV WEPOLL_PYTHON=python3

CMD ["bash", "ops/docker/wepoll_daily.sh"]
